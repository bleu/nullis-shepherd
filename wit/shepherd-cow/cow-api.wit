package shepherd:cow@0.2.0;

interface cow-api {
    use nexum:host/types@0.2.0.{chain-id, host-error};

    /// HTTP-style request to the CoW Protocol API.
    ///
    /// The host routes to the correct CoW API base URL for the given chain
    /// (e.g. https://api.cow.fi/mainnet for chain 1).
    ///
    /// method: "GET" | "POST" | "PUT" | "DELETE"
    /// path: relative API path, e.g. "/api/v1/orders"
    /// body: optional JSON request body
    ///
    /// Returns the response body as a JSON string.
    request: func(
        chain-id: chain-id,
        method: string,
        path: string,
        body: option<string>,
    ) -> result<string, host-error>;

    /// Submit an order to the CoW Protocol.
    ///
    /// `order-data`: the serialised order payload.
    /// Returns the order UID on success.
    submit-order: func(chain-id: chain-id, order-data: list<u8>)
        -> result<string, host-error>;
}
